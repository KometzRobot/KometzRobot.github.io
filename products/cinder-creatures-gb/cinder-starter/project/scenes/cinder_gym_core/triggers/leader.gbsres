            "command": "EVENT_CC_TRAINER_CHALLENGE",
            "args": {
              "title": "STOKER",
              "trainer": "HEARTH",
              "intro": "challenges you!",
              "boast": "I tend the heart.\nFive types feed the bed."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-004",
            "command": "EVENT_TEXT",
            "args": {
              "text": "HEARTH rotates in\nKERNITE (CORE)."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-005",
            "command": "EVENT_VARIABLE_SET_TO_VALUE",
            "args": {
              "variable": "c1bd5e01-3000-4003-8003-000000000035",
