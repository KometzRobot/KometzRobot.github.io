        ],
        "false": [
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-002",
            "command": "EVENT_TEXT",
            "args": {
              "text": "STOKER HEARTH:\nBed is hot enough.\nFive types in the embers. Bring them."
            }
          },
          {
