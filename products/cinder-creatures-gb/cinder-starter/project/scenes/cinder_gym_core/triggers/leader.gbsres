              "atkVar": "c1bd5e01-3000-4003-8003-000000000033",
              "defVar": "c1bd5e01-3000-4003-8003-000000000034"
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-023",
            "command": "EVENT_TEXT",
            "args": {
              "text": "You attack.\nANDOWL waits for both\nconditions to meet."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-024",
            "command": "EVENT_TEXT",
            "args": {
              "text": "ANDOWL strikes only\nwhen the gate is true."
