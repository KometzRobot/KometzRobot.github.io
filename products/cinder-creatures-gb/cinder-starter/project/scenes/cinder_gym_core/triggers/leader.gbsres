              "atkVar": "c1bd5e01-3000-4003-8003-000000000033",
              "defVar": "c1bd5e01-3000-4003-8003-000000000034"
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-007",
            "command": "EVENT_TEXT",
            "args": {
              "text": "You attack.\nKERNITE absorbs it.\nNo crack appears."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-008",
            "command": "EVENT_TEXT",
            "args": {
              "text": "KERNITE returns slowly.\nThe blow lands flat."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-009",
            "command": "EVENT_TEXT",
            "args": {
              "text": "You chip it through.\nKERNITE fainted."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-020",
            "command": "EVENT_TEXT",
            "args": {
              "text": "HEARTH rotates in\nANDOWL (LOGIC)."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-021",
            "command": "EVENT_VARIABLE_SET_TO_VALUE",
            "args": {
              "variable": "c1bd5e01-3000-4003-8003-000000000035",
