            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-006",
            "command": "EVENT_CC_SET_STATS",
            "args": {
              "idVar": "c1bd5e01-3000-4003-8003-000000000035",
