            "command": "EVENT_TEXT",
            "args": {
              "text": "You attack.\nBUFFROG queues your hit\nfor later."
            }
          },
          {
            "id": "c1bd5e01-4000-4004-8004-0000000000d0-leader-044",
            "command": "EVENT_TEXT",
            "args": {
              "text": "BUFFROG flushes the queue.\nThree blows return."
